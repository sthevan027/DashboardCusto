# Padrão: modo offline (dados mockados, login de teste, sem Supabase).
# Para usar banco e autenticação reais, defina:
# VITE_STANDALONE=0
# e preencha URL e chave anon abaixo.

# VITE_STANDALONE=0
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...anon...

# Conta de demonstração (só modo offline; altere se quiser)
# VITE_DEMO_EMAIL=demo@dashboardcusto.local
# VITE_DEMO_PASSWORD=demonstracao

# Opcional: rótulo no cabeçalho quando usar Supabase
# VITE_CONTRACT_LABEL=Contrato ABC
